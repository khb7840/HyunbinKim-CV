@article{Kim2026Structural,
  author   = {\textbf{Hyunbin Kim}
              and Kim, Rachel Seongeun
              and Mirdita, Milot
              and Yoon, Jaewon
              and Steinegger, Martin},
  title    = {Structural motif search across the protein universe with {F}olddisco},
  journal  = {Nature Biotechnology},
  year     = {2026},
  month    = {Jun},
  day      = {05},
  abstract = {Detecting similar protein structural motifs in large structure collections is computationally expensive. We developed Folddisco, a fast structural motif search tool that uses an index of position-independent geometric features, including side-chain orientation, combined with a rarity-based scoring system. Folddisco is 20-fold faster in querying and fourfold more storage-efficient than existing methods while improving accuracy. Folddisco is freely available online (https://folddisco.foldseek.com), along with a webserver (https://search.foldseek.com/folddisco).},
  issn     = {1546-1696},
  doi      = {10.1038/s41587-026-03162-9},
  url      = {https://doi.org/10.1038/s41587-026-03162-9}
}